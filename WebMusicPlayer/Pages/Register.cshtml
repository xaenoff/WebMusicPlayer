@page
@model WebMusicPlayer.Pages.RegisterModel
@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="ru">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Регистрация - WebMusicPlayer</title>
    <link rel="stylesheet" href="lib/bootstrap/dist/css/bootstrap.min.css" />
    <style>
        body { background-color: #121212; color: #fff; }
        .reg-box { max-width: 450px; margin: 80px auto; padding: 30px; background: #1e1e1e; border-radius: 12px; }
    </style>
</head>
<body>
    <div class="reg-box">
        <h3 class="mb-4">Регистрация</h3>

        @if (!string.IsNullOrEmpty(Model.Message))
        {
            <div class="alert alert-info">@Model.Message</div>
        }

        @if (Model.Step == 1)
        {
            <form method="post">
                <div class="mb-3">
                    <label class="form-label">Email</label>
                    <input asp-for="Email" class="form-control" type="email" required />
                </div>
                <div class="mb-3">
                    <label class="form-label">Пароль</label>
                    <input asp-for="Password" class="form-control" type="password" required />
                </div>
                <div class="mb-3">
                    <label class="form-label">Подтвердите пароль</label>
                    <input asp-for="ConfirmPassword" class="form-control" type="password" required />
                </div>
                <button type="submit" class="btn btn-success w-100">Зарегистрироваться</button>
            </form>
        }
        else
        {
            <div class="alert alert-warning">
                <h5> Код отправлен</h5>
                <p>На <b>@Model.Email</b> отправлен код подтверждения.</p>
                <p>Откройте <b>View → Output → Debug</b> в Visual Studio, чтобы увидеть его.</p>
            </div>

            <form method="post">
                <input type="hidden" asp-for="Step" value="2" />
                <input type="hidden" asp-for="Email" value="@Model.Email" />

                <div class="mb-3">
                    <label class="form-label">Введите код</label>
                    <input asp-for="Code" class="form-control" placeholder="123456" maxlength="6" required />
                </div>
                <button type="submit" class="btn btn-success w-100">Подтвердить email</button>
            </form>
        }

        <p class="mt-3 text-center">
            Уже есть аккаунт? <a href="/Login" class="text-success">Войти</a>
        </p>
    </div>
</body>
</html>