@page "/admin/tracks"
@attribute [Authorize(Roles = "Admin")]
@layout AdminLayout
@rendermode InteractiveServer
@inject IMusicService MusicService

<h3 style="color: white; margin-bottom: 30px;">Управление треками</h3>

<div style="margin-bottom: 20px; display: flex; gap: 10px;">
    <input type="text"
           @bind="searchQuery"
           @oninput="OnSearchInput"
           placeholder="Поиск по названию или исполнителю..."
           class="form-control"
           style="max-width: 300px;" />
    <a href="/admin/tracks/upload" class="btn btn-primary">➕ Добавить трек</a>
</div>

@if (tracks == null)
{
    <p style="color: #888;">Загрузка...</p>
}
else if (!GetFilteredTracks().Any())
{
    <p style="color: #888;">
        @(string.IsNullOrWhiteSpace(searchQuery)
            ? "Треков пока нет. <a href='/admin/tracks/upload' style='color: white;'>Загрузи первый!</a>"
            : "Ничего не найдено по запросу.")
    </p>
}
else
{
    <table style="width: 100%; border-collapse: collapse; color: white;">
        <thead>
            <tr style="border-bottom: 2px solid #333; text-align: left;">
                <th style="padding: 12px;">#</th>
                <th style="padding: 12px;">Название</th>
                <th style="padding: 12px;">Исполнитель</th>
                <th style="padding: 12px;">Жанр</th>
                <th style="padding: 12px;">Длительность</th>
                <th style="padding: 12px; text-align: right;">Действия</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var track in GetFilteredTracks())
            {
                <tr style="border-bottom: 1px solid #222;">
                    <td style="padding: 12px; color: #666;">@track.Id</td>
                    <td style="padding: 12px;">@track.Title</td>
                    <td style="padding: 12px;">@track.Artist</td>
                    <td style="padding: 12px; color: #888;">@(track.Genre?.Name ?? "—")</td>
                    <td style="padding: 12px; color: #888;">@FormatTime(track.DurationSeconds)</td>
                    <td style="padding: 12px; text-align: right;">
                        <a href="/admin/tracks/edit/@track.Id" class="btn-action btn-edit" title="Редактировать">✏️</a>
                        <button @onclick="() => ConfirmDelete(track.Id, track.Title)" class="btn-action btn-delete" title="Удалить">🗑️</button>
                    </td>
                </tr>
            }
        </tbody>
    </table>
}

@if (showDeleteConfirm)
{
    <div class="modal-overlay" @onclick="CancelDelete">
        <div class="modal-content" @onclick:stopPropagation>
            <h4 style="color: white; margin-bottom: 20px;">Подтверждение удаления</h4>
            <p style="color: #ccc; margin-bottom: 30px;">
                Вы действительно хотите скрыть трек <strong>"@deleteTrackTitle"</strong>?<br />
                <small style="color: #888;">(Трек не удалится из БД, но перестанет отображаться в каталоге)</small>
            </p>
            <div style="display: flex; gap: 10px; justify-content: flex-end;">
                <button @onclick="CancelDelete" class="btn btn-secondary">Отмена</button>
                <button @onclick="ExecuteDelete" class="btn btn-danger">Да, скрыть трек</button>
            </div>
        </div>
    </div>
}

@code {
    private List<Track>? tracks;
    private string searchQuery = "";

    private bool showDeleteConfirm = false;
    private int deleteTrackId = 0;
    private string deleteTrackTitle = "";

    protected override async Task OnInitializedAsync()
    {
        await LoadTracksAsync();
    }

    private async Task LoadTracksAsync()
    {
        tracks = await MusicService.GetAllTracksAsync();
        StateHasChanged();
    }

    private IEnumerable<Track> GetFilteredTracks()
    {
        if (tracks == null) return Enumerable.Empty<Track>();
        if (string.IsNullOrWhiteSpace(searchQuery)) return tracks;

        var query = searchQuery.ToLowerInvariant();
        return tracks.Where(t =>
            t.Title.ToLowerInvariant().Contains(query) ||
            t.Artist.ToLowerInvariant().Contains(query));
    }

    private void OnSearchInput(ChangeEventArgs e)
    {
        searchQuery = e.Value?.ToString() ?? "";
        StateHasChanged();
    }

    private void ConfirmDelete(int trackId, string trackTitle)
    {
        deleteTrackId = trackId;
        deleteTrackTitle = trackTitle;
        showDeleteConfirm = true;
        StateHasChanged();
    }

    private void CancelDelete()
    {
        showDeleteConfirm = false;
        deleteTrackId = 0;
        deleteTrackTitle = "";
        StateHasChanged();
    }

    private async Task ExecuteDelete()
    {
        try
        {
            await MusicService.SoftDeleteTrackAsync(deleteTrackId);
            await LoadTracksAsync();
            showDeleteConfirm = false;
        }
        catch (Exception ex)
        {
            Console.WriteLine($"[TracksList] Ошибка удаления: {ex.Message}");
        }
    }

    private string FormatTime(int seconds)
    {
        if (seconds <= 0) return "0:00";
        var ts = TimeSpan.FromSeconds(seconds);
        return ts.Hours > 0 ? $"{ts.Hours}:{ts.Minutes:D2}:{ts.Seconds:D2}" : $"{ts.Minutes}:{ts.Seconds:D2}";
    }
}

<style>
    .form-control {
        padding: 8px 12px;
        background: #111;
        border: 1px solid #333;
        color: white;
        border-radius: 4px;
        font-size: 14px;
    }

        .form-control:focus {
            border-color: #555;
            outline: none;
        }

    .btn {
        padding: 8px 16px;
        border: none;
        border-radius: 4px;
        font-size: 13px;
        cursor: pointer;
        text-decoration: none;
        display: inline-flex;
        align-items: center;
        gap: 6px;
    }

    .btn-primary {
        background: white;
        color: black;
        font-weight: bold;
    }

        .btn-primary:hover {
            background: #ddd;
        }

    .btn-action {
        padding: 6px 10px;
        margin-left: 8px;
        background: transparent;
        border: 1px solid #333;
        color: #888;
        font-size: 14px;
        cursor: pointer;
        border-radius: 4px;
        transition: all 0.2s;
    }

    .btn-edit:hover {
        border-color: #4CAF50;
        color: #4CAF50;
    }

    .btn-delete:hover {
        border-color: #f44336;
        color: #f44336;
    }

    .btn-danger {
        background: #f44336;
        color: white;
    }

        .btn-danger:hover {
            background: #d32f2f;
        }

    .btn-secondary {
        background: #333;
        color: white;
    }

        .btn-secondary:hover {
            background: #444;
        }

    .modal-overlay {
        position: fixed;
        top: 0;
        left: 0;
        right: 0;
        bottom: 0;
        background: rgba(0,0,0,0.7);
        display: flex;
        align-items: center;
        justify-content: center;
        z-index: 1000;
    }

    .modal-content {
        background: #111;
        border: 1px solid #333;
        border-radius: 8px;
        padding: 24px;
        min-width: 320px;
        max-width: 90%;
    }
</style>