@* Components/Shared/FavoriteButton.razor *@
@inject IMusicService MusicService
@inject AuthenticationStateProvider AuthState

<button class="btn-favorite @(IsFavorite ? "active" : "")"
@onclick:stopPropagation
        @onclick="ToggleFavoriteAsync"
        disabled="@isLoading"
        title="@(IsFavorite ? "Убрать из избранного" : "Добавить в избранное")">
    @if (isLoading)
    {
        <!-- Индикатор загрузки -->
        <span style="font-size: 14px; line-height: 1;">⏳</span>
    }
    else
    {
        <!-- SVG Сердечко -->
        <svg viewBox="0 0 24 24" width="20" height="20">
            <path d="M12 21.35l-1.45-1.32C5.4 15.36 2 12.28 2 8.5 2 5.42 4.42 3 7.5 3c1.74 0 3.41.81 4.5 2.09C13.09 3.81 14.76 3 16.5 3 19.58 3 22 5.42 22 8.5c0 3.78-3.4 6.86-8.55 11.54L12 21.35z" />
        </svg>
    }
</button>

@code {
    [Parameter] public int TrackId { get; set; }
    [Parameter] public bool IsFavorite { get; set; }
    [Parameter] public Action<bool>? OnChanged { get; set; }

    private bool isLoading = false;

    private async Task ToggleFavoriteAsync()
    {
        if (isLoading) return;
        isLoading = true;
        StateHasChanged(); // Обновляем UI

        try
        {
            var auth = await AuthState.GetAuthenticationStateAsync();
            var userIdClaim = auth.User.FindFirst("UserId");

            if (userIdClaim != null && int.TryParse(userIdClaim.Value, out int userId))
            {
                if (IsFavorite)
                {
                    await MusicService.RemoveFromFavoriteAsync(userId, TrackId);
                }
                else
                {
                    await MusicService.AddToFavoriteAsync(userId, TrackId);
                }

                bool newState = !IsFavorite;
                OnChanged?.Invoke(!IsFavorite);
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Favorite error: {ex.Message}");
        }
        finally
        {
            isLoading = false;
            StateHasChanged(); // Возвращаем кнопку в активное состояние
        }
    }
}